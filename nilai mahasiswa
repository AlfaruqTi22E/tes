public class NilaiMahasiswa extends Mahasiswa {

    private String grade;
    private String status;

    public NilaiMahasiswa(String nim, String nama, double nilai) {
        super(nim, nama, nilai);
        this.grade = tentukanGrade(nilai);
        this.status = tentukanStatus(grade);
    }

    private String tentukanGrade(double nilai) {
        if (nilai < 0 || nilai > 100) {
            return "INVALID";
        } else if (nilai >= 80) {
            return "A";
        } else if (nilai >= 70) {
            return "B";
        } else if (nilai >= 60) {
            return "C";
        } else if (nilai >= 50) {
            return "D";
        } else {
            return "E";
        }
    }

    private String tentukanStatus(String grade) {
        if (grade.equals("A") || grade.equals("B") || grade.equals("C")) {
            return "Lulus";
        } else if (grade.equals("D") || grade.equals("E")) {
            return "Tidak Lulus";
        } else {
            return "Invalid";
        }
    }

    public String getGrade() { return grade; }
    public String getStatus() { return status; }

    @Override
    public void tampilData() {
        if (grade.equals("INVALID")) {
            System.out.println("Input nilai anda salah");
            return;
        }
        super.tampilData();
        System.out.println("Grade : " + grade);
    }
}
